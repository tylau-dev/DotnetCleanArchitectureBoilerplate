root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
[*.cs]
indent_style = space
indent_size = 4

# Roslyn Analyzers - Microsoft.CodeAnalysis.NetAnalyzers
# https://github.com/dotnet/roslyn-analyzers

